# API publique consommée par les sites démo
NUXT_PUBLIC_API_BASE=http://localhost:8000

# PostHog — CAPTURE du comportement sur les sites démo.
# Optionnel : clé vide → tracking désactivé. Ne tourne QUE sur une démo
# (status=active), jamais sur un site livré au client.
# Project API Key (phc_, PUBLIQUE — embarquée dans le navigateur).
NUXT_PUBLIC_POSTHOG_PROJECT_API_KEY=phc_xxxxxxxxxxxx
# Host d'ingestion (EU: https://eu.i.posthog.com, US: https://us.i.posthog.com)
NUXT_PUBLIC_POSTHOG_INGESTION_HOST=https://eu.i.posthog.com
