# Environment
ENV=development
DEBUG=true

# Encryption
ENCRYPTION_KEY=your-fernet-encryption-key-here  # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:1420,https://demo.dibodev.fr

# Database
DATABASE_URL=mysql+pymysql://root:root@localhost:3310/devleadhunter

# JWT
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin User
ADMIN_EMAIL=contact@dibodev.fr
ADMIN_PASSWORD=admin123
STRIPE_SECRET_KEY=****
STRIPE_PUBLIC_KEY=*****
STRIPE_WEBHOOK_SECRET=whsec_... # Secret du webhook Stripe
FRONTEND_URL=http://localhost:3000  # URL de votre frontend

# Demo site builder (Storyblok + demo-host)
# Local dev: demo-host on port 3001 — same flow as prod, local DB only.
DEMO_HOST_BASE_URL=http://localhost:3001
DEMO_SITE_VERIFY_RETRIES=3
DEMO_SITE_VERIFY_RETRY_DELAY_SECONDS=2
DEMO_SITE_TTL_DAYS=14
# Storyblok: use a DEV token (separate from prod) or leave empty for mock mode.
STORYBLOK_MANAGEMENT_TOKEN=
STORYBLOK_REGION=eu
# Scraping (nodriver / Chrome)
# Visible Chrome by default (like GoupixDex) — set true on headless servers
SCRAPER_BROWSER_HEADLESS=false
# Leave Chrome open after a job for debugging (optional)
# SCRAPER_BROWSER_KEEP_OPEN=true
# Enrichir avec email Google pendant le scrape (lent, 2e Chrome)
SCRAPER_INLINE_EMAIL=false
# Pause before closing visible Chrome (seconds)
SCRAPER_BROWSER_CLOSE_DELAY_SEC=3
# Optional: path to chrome.exe if not on PATH
# SCRAPER_CHROME_EXECUTABLE=
# Optional: persistent profile (auto-set when visible on Windows)
# SCRAPER_USER_DATA_DIR=

# Resend (cold email provider — primary)
# 1. Créer un compte sur resend.com
# 2. Vérifier ton domaine d'envoi (SPF + DKIM)
# 3. Créer une API key dans Settings > API Keys
# 4. Activer le tracking d'ouverture dans Settings > Email Tracking
# 5. Configurer le webhook : Settings > Webhooks → POST /api/v1/webhooks/resend
#    Events : email.sent, email.delivered, email.opened, email.clicked, email.bounced, email.complained
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# BrightData HTTP API (Web Unlocker)
BRIGHTDATA_API_TOKEN=your-brightdata-api-token
BRIGHTDATA_ZONE=mcp_unlocker

# Vercel (demo site deployments)
VERCEL_TOKEN=your-vercel-token