# Environment
ENV=development
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:1420,https://demo.dibodev.fr

# Database
DATABASE_URL=mysql+pymysql://root:root@localhost:3310/devleadhunter

# JWT
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin User
ADMIN_EMAIL=contact@dibodev.fr
ADMIN_PASSWORD=admin123
STRIPE_SECRET_KEY=****
STRIPE_PUBLIC_KEY=*****
STRIPE_WEBHOOK_SECRET=whsec_... # Secret du webhook Stripe
FRONTEND_URL=http://localhost:3000  # URL de votre frontend

# Demo site builder (Storyblok + demo.dibodev.fr)
# Local and prod both use the Vercel-hosted demo host.
DEMO_HOST_BASE_URL=https://demo.dibodev.fr
DEMO_SITE_VERIFY_RETRIES=3
DEMO_SITE_VERIFY_RETRY_DELAY_SECONDS=2
DEMO_SITE_TTL_DAYS=14
STORYBLOK_MANAGEMENT_TOKEN=
STORYBLOK_REGION=eu
VERCEL_TOKEN=