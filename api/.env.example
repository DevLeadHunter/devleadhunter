# Environment
ENV=development
DEBUG=true

# Encryption
ENCRYPTION_KEY=your-fernet-encryption-key-here  # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:1420,https://demo.dibodev.fr

# Database
DATABASE_URL=mysql+pymysql://root:root@localhost:3310/devleadhunter

# JWT
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
# Access token lifetime in minutes. 10080 = 7 days (no refresh token yet, so
# sessions are kept long-lived to avoid frequent re-logins).
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Admin User
ADMIN_EMAIL=contact@dibodev.fr
ADMIN_PASSWORD=admin123
STRIPE_SECRET_KEY=****
STRIPE_PUBLIC_KEY=*****
STRIPE_WEBHOOK_SECRET=whsec_... # Secret du webhook Stripe
FRONTEND_URL=http://localhost:3000  # URL de votre frontend

# Demo site builder (Storyblok + demo-host)
# Local dev: demo-host on port 3001 — same flow as prod, local DB only.
DEMO_HOST_BASE_URL=http://localhost:3001
DEMO_SITE_VERIFY_RETRIES=3
DEMO_SITE_VERIFY_RETRY_DELAY_SECONDS=2
DEMO_SITE_TTL_DAYS=14
# Storyblok: use a DEV token (separate from prod) or leave empty for mock mode.
STORYBLOK_MANAGEMENT_TOKEN=
STORYBLOK_REGION=eu
# Optional: signs the Storyblok publish webhook (content_json sync). Any random secret.
STORYBLOK_WEBHOOK_SECRET=
# PageSpeed Insights (Lighthouse audit of prospect websites in the drawer).
# Free key via Google Cloud Console — without it the shared anonymous quota 429s quickly.
PAGESPEED_API_KEY=
# Gmail Postmaster Tools — Gmail-side reputation on the Email health page (free, read-only).
# Local dev: point to the downloaded service-account JSON key file.
GOOGLE_POSTMASTER_CREDENTIALS_FILE=
# Prod alternative: paste the key inline (raw JSON or base64 of it) instead of a file.
# When set, this wins over the file path. Leave both empty to hide the feature.
GOOGLE_POSTMASTER_CREDENTIALS_JSON=
# Scraping (nodriver / Chrome)
# Visible Chrome by default (like GoupixDex) — set true on headless servers
SCRAPER_BROWSER_HEADLESS=false
# Leave Chrome open after a job for debugging (optional)
# SCRAPER_BROWSER_KEEP_OPEN=true
# Pause before closing visible Chrome (seconds)
SCRAPER_BROWSER_CLOSE_DELAY_SEC=3
# Optional: path to chrome.exe if not on PATH
# SCRAPER_CHROME_EXECUTABLE=
# Optional: persistent profile (auto-set when visible on Windows)
# SCRAPER_USER_DATA_DIR=

# Resend (cold email provider — primary)
# 1. Créer un compte sur resend.com
# 2. Vérifier ton domaine d'envoi (SPF + DKIM)
# 3. Créer une API key dans Settings > API Keys
# 4. Activer le tracking d'ouverture dans Settings > Email Tracking
# 5. Configurer le webhook : Settings > Webhooks → POST /api/v1/webhooks/resend
#    Events : email.sent, email.delivered, email.opened, email.clicked, email.bounced, email.complained
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# BrightData HTTP API (Web Unlocker)
BRIGHTDATA_API_TOKEN=your-brightdata-api-token
BRIGHTDATA_ZONE=mcp_unlocker

# Vercel (demo site deployments + mise en ligne prod du site vendu)
VERCEL_TOKEN=your-vercel-token
# Projet Vercel global (= projet demo-host) auquel on attache le domaine client
VERCEL_DEMO_HOST_PROJECT_ID=prj_xxxxxxxxxxxx
# Deploy Hook du projet demo-host pour déclencher un rebuild prod
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxxxxxxxxxxx/xxxxxxxx

# PostHog — LECTURE des events côté API (scoring chaud/froid, timeline, résumé IA).
# App/API host (requêtes) — EU: https://eu.posthog.com, US: https://us.posthog.com
POSTHOG_API_HOST=https://eu.posthog.com
# Id numérique du projet PostHog
POSTHOG_PROJECT_ID=12345
# Personal API Key (phx_, SECRÈTE, scope read/query) — jamais exposée au navigateur
POSTHOG_PERSONAL_API_KEY=phx_xxxxxxxxxxxx
# Capture serveur des events email → PostHog (funnels email↔démo)
# Project API Key (phc_, même valeur que NUXT_PUBLIC_POSTHOG_PROJECT_API_KEY côté demo-host)
POSTHOG_PROJECT_API_KEY=phc_xxxxxxxxxxxx
POSTHOG_INGESTION_HOST=https://eu.i.posthog.com

# Groq — résumé IA + relance personnalisée (fallback règles si absent)
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.3-70b-versatile           # optionnel (défaut déjà en place)

# Dev — redirige TOUS les emails sortants vers cette adresse (sécurité dev : rien
# n'atteint les vrais clients). Laisser VIDE en production.
DEV_EMAIL_REDIRECT=dibodevcode@gmail.com