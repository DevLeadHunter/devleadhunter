{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevLeadHunter",
  "version": "0.1.0",
  "identifier": "fr.dibodev.devleadhunter",
  "build": {
    "beforeDevCommand": "cross-env NUXT_DESKTOP_BUILD=1 nuxt dev --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run desktop:generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "DevLeadHunter",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["../public/favicon.ico", "../public/apple-touch-icon.png"]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/leogu/devleadhunter/releases/download/desktop/latest.json"],
      "pubkey": "__TAURI_UPDATER_PUBKEY__"
    }
  }
}
