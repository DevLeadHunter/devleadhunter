{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevLeadHunter",
  "version": "0.1.0",
  "identifier": "fr.dibodev.devleadhunter",
  "build": {
    "beforeDevCommand": "node scripts/dev-desktop.mjs",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run desktop:generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "DevLeadHunter",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "minWidth": 1100,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/devleadhunter/devleadhunter/releases/latest/download/latest.json"],
      "pubkey": "__TAURI_UPDATER_PUBKEY__"
    }
  }
}
