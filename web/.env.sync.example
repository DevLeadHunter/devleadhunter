# Prod → local DB sync (desktop dev only) — used by the "Sync DB prod → local" button.
# Copy to web/.env.sync (gitignored) and fill in. api/.env.sync is also loaded if present.
#
# Requirements:
#   - Your dev machine's PUBLIC IP must be allowlisted on the prod DB host.
#   - The prod SQL user only needs SELECT + SHOW VIEW (read-only dump).
#   - A '#' in a password truncates the .cnf line — avoid '#' in DLH_SYNC_PROD_PASSWORD.
#   - Without local mysql/mysqldump clients, Docker Desktop is enough (image mariadb:11).

# ── Prod (source, read-only) ─────────────────────────────────────────────
DLH_SYNC_PROD_HOST=your-prod-db-host
DLH_SYNC_PROD_PORT=3306
DLH_SYNC_PROD_USER=your_prod_readonly_user
DLH_SYNC_PROD_PASSWORD=
DLH_SYNC_PROD_DATABASE=devleadhunter

# ── Local (target, overwritten) ──────────────────────────────────────────
DLH_SYNC_LOCAL_HOST=127.0.0.1
DLH_SYNC_LOCAL_PORT=3310
DLH_SYNC_LOCAL_USER=root
DLH_SYNC_LOCAL_PASSWORD=root
DLH_SYNC_LOCAL_DATABASE=devleadhunter

# ── Optional tuning ──────────────────────────────────────────────────────
# auto (default): use host mysql/mysqldump if present, else Docker. always | never also valid.
# DLH_SYNC_USE_DOCKER=auto
# DLH_SYNC_DOCKER_IMAGE=mariadb:11
# When syncing via Docker, how the container reaches your host's local DB:
# DLH_SYNC_LOCAL_DOCKER_HOST=host.docker.internal
# Override client binaries if not named mysqldump / mysql / docker on PATH:
# DLH_MYSQLDUMP_BIN=mysqldump
# DLH_MYSQL_BIN=mysql
# DLH_DOCKER_BIN=docker
